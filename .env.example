# Copy of the env names this app needs. Values live in Vercel (Project → Settings →
# Environment Variables); pull them locally with `npx vercel env pull .env.local`.
# Both come from the Supabase dashboard: Project → Settings → API Keys.
# URL = the project URL; key = the "Publishable key" (sb_publishable_…) —
# a legacy anon JWT works too. Both are safe to expose publicly.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
